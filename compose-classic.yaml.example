services:
  database:
    image: ghcr.io/mserajnik/cmangos-database-classic
    restart: unless-stopped
    # The healthcheck determines if the container is working as expected; if
    # the healthcheck fails it causes a restart of the container. The default
    # parameters here should work fine on most systems, but if you experience
    # any issues, you might want to adjust them.
    healthcheck:
      test: ['CMD', 'cmangos-healthcheck']
      interval: 1m
      timeout: 3s
      retries: 5
      start_period: 24h # Keeps the container in `starting` (not `unhealthy`) while cmangos-deploy halts startup for manual changes; adjust if you want a tighter window.
    volumes:
      - cmangos-database-classic:/var/lib/mysql
      - ./storage/classic/database/custom-sql:/sql/custom:ro
    environment:
      - TZ=Etc/UTC # Change this to your desired time zone (usually you want to match your host system's time zone).
      - MARIADB_USER=mangos # Specifies the name for the database user utilized by CMaNGOS (must match the credentials in the CMaNGOS configuration files); please note that the name cannot be changed using this environment variable after the initial startup.
      - MARIADB_PASSWORD=mangos # Specifies the password for the database user utilized by CMaNGOS (must match the credentials in the CMaNGOS configuration files); please note that the password cannot be changed using this environment variable after the initial startup.
      - MARIADB_ROOT_PASSWORD=password # Specifies the password for the database's `root` user (not used by CMaNGOS itself, only for database creation/updates); please note that the password cannot be changed using this environment variable after the initial startup.
      # Only a subset covering the most important realmlist parameters is
      # exposed in this configuration file. Altering them here after the
      # database has been created will _not_ update them, but you can always
      # change them (and the other parameters not exposed here) manually in the
      # database at any point (see the `phpmyadmin` service further below).
      - CMANGOS_REALMLIST_NAME=CMaNGOS Classic # Sets the name of the realm as it appears in the selection list and the character screen.
      - CMANGOS_REALMLIST_ADDRESS=127.0.0.1 # Sets the LAN or WAN address of the realm; this can also be a domain name.
      - CMANGOS_REALMLIST_PORT=8085 # Sets the port of the realm; changing this means it also needs to be changed in other places.
      - CMANGOS_REALMLIST_ICON=1 # Sets the icon of the realm; 0 = Normal, 1 = PvP, 6 = RP, 8 = RP PVP.
      - CMANGOS_REALMLIST_TIMEZONE=0 # Sets the time zone of the realm; some common values are: 2 = United States, 3 = Oceanic, 4 = Latin America, 8 = English, 9 = German, 10 = French, 11 = Spanish, 12 = Russian.
      - CMANGOS_REALMLIST_ALLOWED_SECURITY_LEVEL=0 # Sets the minimum account security level required to log in to the realm; 0 = regular players.
      # cmangos-deploy keeps track of upstream CMaNGOS commits that edit
      # already released migration files, which would otherwise leave your
      # world database in an inconsistent state when updating and require
      # manual intervention to rectify. In such cases, cmangos-deploy can
      # automatically re-create your world database. Anything in the world
      # database that you may have changed (your custom NPCs and gameobjects,
      # `npc_vendor` edits, etc.) does not survive the re-creation, so restore
      # those from a backup if you need them back. It is strongly suggested to
      # keep this feature enabled.
      # If you do decide to disable it (by setting the following environment
      # variable to `0`), cmangos-deploy will halt startup instead and ask you
      # to apply the SQL by hand (see the next environment variable).
      - CMANGOS_ENABLE_AUTOMATIC_WORLD_DB_CORRECTIONS=1
      # cmangos-deploy also detects migration edits in databases that contain
      # user state (player characters, accounts, etc.). Because of this they
      # cannot be safely re-created. Instead, cmangos-deploy halts startup and
      # waits for you to apply the equivalent SQL manually, then continues
      # after you run `docker compose exec database cmangos-confirm-changes`.
      # This setting also controls the world database fallback when the
      # previous environment variable is set to `0`. It is strongly suggested
      # to keep this feature enabled.
      # If you do decide to disable it (by setting the following environment
      # variable to `0`), cmangos-deploy will log a warning and continue
      # without acknowledging the edit (so the warning will repeat on every
      # start until you take action).
      - CMANGOS_HALT_ON_MIGRATION_EDITS=1
      # If you want to make custom changes to the world database, it is
      # recommended to do so using SQL files and placing them in
      # `./storage/classic/database/custom-sql` (a bind mount for this
      # directory is configured out-of-the-box, as can be seen further above).
      # This way, you can keep automatic world database corrections enabled
      # without having to worry about your changes getting lost.
      # By default, all SQL files (files with a `.sql` extension) in that
      # directory will be processed during each startup in alphabetical order
      # (after the world database has been created and updated with the latest
      # migrations). Thus, the SQL statements in your files have to be
      # idempotent (i.e., they can be processed multiple times without causing
      # issues).
      # If you want to disable this feature, set the following environment
      # variable to `0`; while this also allows you to use SQL files containing
      # non-idempotent statements (by setting the environment variable to `0`
      # after the SQL files have been processed once), this is not recommended
      # and should be avoided.
      - CMANGOS_PROCESS_CUSTOM_SQL=1

  realmd:
    image: ghcr.io/mserajnik/cmangos-server-classic
    # If you are using a Linux host and your user's UID and GID are not 1000,
    # change these values to reflect your user's UID and GID. This will cause
    # the user in the container to use the same UID and GID and prevent
    # permission issues on the bind mounts.
    # If you are on Windows or macOS, you can ignore this.
    user: 1000:1000
    command: realmd
    depends_on:
      database:
        condition: service_healthy
    restart: unless-stopped
    # The healthcheck determines if the container is working as expected; if
    # the healthcheck fails it causes a restart of the container. The default
    # parameters here should work fine on most systems, but if you experience
    # any issues, you might want to adjust them.
    healthcheck:
      test: ['CMD', 'nc', '-z', 'localhost', '3724']
      interval: 1m
      timeout: 3s
      retries: 5
      start_period: 5m
    ports:
      - 3724:3724
    volumes:
      - ./config/classic/realmd.conf:/opt/cmangos/config/realmd.conf:ro
      - ./storage/classic/realmd/logs:/opt/cmangos/storage/logs
    environment:
      - TZ=Etc/UTC # Change this to your desired time zone (usually you want to match your host system's time zone).

  mangosd:
    image: ghcr.io/mserajnik/cmangos-server-classic
    # If you are using a Linux host and your user's UID and GID are not 1000,
    # change these values to reflect your user's UID and GID. This will cause
    # the user in the container to use the same UID and GID and prevent
    # permission issues on the bind mounts.
    # If you are on Windows or macOS, you can ignore this.
    user: 1000:1000
    command: mangosd
    tty: true
    stdin_open: true
    depends_on:
      database:
        condition: service_healthy
    restart: unless-stopped
    # `stop_grace_period` configures how long Docker waits during shutdown
    # before it kills the container. The Docker default is 10 seconds, which
    # might be too short for CMaNGOS servers with larger populations to
    # complete the shutdown tasks in time. Setting it to 2 minutes instead
    # should be on the safe side and does not have any downsides except the
    # longer wait time when the server actually hangs during shutdown. Feel
    # free to adjust this value based on the actual shutdown duration you
    # observe.
    stop_grace_period: 2m
    # The healthcheck determines if the container is working as expected; if
    # the healthcheck fails it causes a restart of the container. The default
    # parameters here should work fine on most systems, but if you experience
    # any issues, you might want to adjust them.
    healthcheck:
      test: ['CMD', 'nc', '-z', 'localhost', '8085']
      interval: 1m
      timeout: 3s
      retries: 5
      start_period: 30m # This is set relatively high for the initial Playerbot account and character setup; adjust as required.
    ports:
      - 8085:8085
      # To enable SOAP API access, set `SOAP.Enabled` to `1` and make sure
      # `SOAP.IP` is set to `0.0.0.0` and `SOAP.Port` to `7878` in your
      # `./config/classic/mangosd.conf`, then uncomment the following port
      # mapping:
      # - 7878:7878
      # To enable RA, set `Ra.Enable` to `1` and make sure `Ra.IP` is set to
      # `0.0.0.0` and `Ra.Port` to `3443` in your
      # `./config/classic/mangosd.conf`, then uncomment the following port
      # mapping:
      # - 3443:3443
    volumes:
      - ./config/classic/mangosd.conf:/opt/cmangos/config/mangosd.conf:ro
      - ./config/classic/anticheat.conf:/opt/cmangos/config/anticheat.conf:ro
      - ./config/classic/ahbot.conf:/opt/cmangos/config/ahbot.conf:ro
      - ./config/classic/aiplayerbot.conf:/opt/cmangos/config/aiplayerbot.conf:ro
      - ./config/classic/mods.conf:/opt/cmangos/config/mods.conf:ro
      - ./storage/classic/mangosd/extracted-data:/opt/cmangos/storage/data:ro
      - ./storage/classic/mangosd/logs:/opt/cmangos/storage/logs
    environment:
      - TZ=Etc/UTC # Change this to your desired time zone (usually you want to match your host system's time zone).

  # # Optional:
  # # Uncomment this service to enable periodic database backups.
  # # The default configuration should work out of the box (unless you have
  # # modified the `database` service configuration) and will create a backup
  # # every day at 04:00 (change the `TIMEZONE` environment variable to your
  # # desired time zone). Backups older than a week will automatically get
  # # deleted.
  # # Backups will be stored in `./storage/classic/database/backups`.
  # # See https://github.com/tiredofit/docker-db-backup#configuration for more
  # # information.
  # database-backup:
  #   image: tiredofit/db-backup
  #   depends_on:
  #     database:
  #       condition: service_healthy
  #   restart: unless-stopped
  #   volumes:
  #     - ./storage/classic/database/backups:/backup
  #   environment:
  #     - TIMEZONE=Etc/UTC # Change this to your desired time zone (usually you want to match your host system's time zone).
  #     - CONTAINER_ENABLE_MONITORING=FALSE
  #     # If you are using a Linux host and your user's UID and GID are not 1000,
  #     # change these next two variables to reflect your user's UID and GID.
  #     # This will cause the user in the container to use the same UID and GID
  #     # and prevent permission issues on the bind mount.
  #     # If you are on Windows or macOS, you can ignore this.
  #     - USER_DBBACKUP=1000
  #     - GROUP_DBBACKUP=1000
  #     - DEFAULT_COMPRESSION=GZ
  #     - DEFAULT_BACKUP_INTERVAL=1440 # How often to run the backup in minutes; 1440 means once per day.
  #     - DEFAULT_BACKUP_BEGIN=0400 # When to start the backup; 0400 means it starts at 04:00.
  #     - DEFAULT_CLEANUP_TIME=10080 # How old backups have to be to get deleted; 10080 means backups older than a week get deleted.
  #     - DB01_TYPE=mariadb
  #     - DB01_HOST=database
  #     - DB01_NAME=characters,realmd # Which databases should be backed up.
  #     - DB01_USER=root
  #     - DB01_PASS=password # Must match the `MARIADB_ROOT_PASSWORD` environment variable of the `database` service.

  # # Optional:
  # # Uncomment this service to run phpMyAdmin, a web-based MySQL/MariaDB
  # # database administration tool.
  # # This can be useful to manage accounts, make changes to the realm
  # # configuration etc.
  # # With the default configuration, you should be able to open
  # # http://localhost:8080 in your browser and have access to all of the
  # # databases CMaNGOS uses.
  # phpmyadmin:
  #   image: phpmyadmin
  #   depends_on:
  #     database:
  #       condition: service_healthy
  #   restart: unless-stopped
  #   ports:
  #     - 8080:80
  #   environment:
  #     - PMA_HOST=database
  #     - PMA_PORT=3306
  #     - PMA_USER=root
  #     - PMA_PASSWORD=password # Must match the `MARIADB_ROOT_PASSWORD` environment variable of the `database` service.

volumes:
  cmangos-database-classic:
